APP_NAME=TuyenSinhCRM
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://192.168.1.20:8080

APP_LOCALE=vi
APP_FALLBACK_LOCALE=vi

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=tuyensinh
# User ứng dụng (khuyến nghị, không dùng root)
DB_USERNAME=tuyensinh
DB_PASSWORD=tuyensinh
# Thông số init MySQL container (user thường để tạo DB + cấp quyền)
DB_APP_USERNAME=tuyensinh
DB_APP_PASSWORD=tuyensinh
DB_ROOT_PASSWORD=root

# Expose ports on host (tuỳ VPS/local)
APP_PORT=8080
DB_PORT_EXPOSE=3307
VITE_PORT=5173
PHPMYADMIN_PORT=8081

SESSION_DRIVER=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=public

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL="http://192.168.1.20:8080/api"

# (tuỳ chọn) map UID/GID user trên VPS để quyền file khớp khi bind-mount
USER_ID=1000
GROUP_ID=1000

